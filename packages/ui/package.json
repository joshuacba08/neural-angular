{
  "name": "@neuralangular/angular-ui",
  "version": "0.1.1",
  "description": "Angular-first UI component library. Modern, accessible, dark-mode ready components built on Angular CDK.",
  "type": "module",
  "license": "MIT",
  "author": "Neural Angular Contributors",
  "homepage": "https://github.com/joshuacba08/neural-angular",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshuacba08/neural-angular.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/joshuacba08/neural-angular/issues"
  },
  "keywords": [
    "angular",
    "ui",
    "components",
    "design-system",
    "angular-material",
    "angular-cdk",
    "dark-mode",
    "neural"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/fesm2022",
    "dist/types",
    "src/styles",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/neuralangular-angular-ui.d.ts",
      "default": "./dist/fesm2022/neuralangular-angular-ui.mjs"
    },
    "./styles": "./src/styles/index.css",
    "./styles/fonts": "./src/styles/neural-fonts.css",
    "./styles/base": "./src/styles/neural-base.css",
    "./styles/tokens": "./src/styles/neural-tokens.css",
    "./styles/dark": "./src/styles/neural-theme.dark.css",
    "./styles/light": "./src/styles/neural-theme.light.css",
    "./styles/material": "./src/styles/neural-material-map.css",
    "./styles/compat": "./src/styles/neural-compat.css"
  },
  "peerDependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@lucide/angular": "^1.18.0",
    "echarts": "^6.1.0"
  },
  "devDependencies": {
    "@angular/cdk": "^22.0.0",
    "@lucide/angular": "^1.18.0",
    "echarts": "^6.1.0"
  }
}