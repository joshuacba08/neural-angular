{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "rootDir": "..",
    "tsBuildInfoFile": "../dist/.storybook/tsconfig.tsbuildinfo"
  },
  "exclude": ["../**/*.spec.ts"],
  "include": [
    "../src/**/*.ts",
    "../src/**/*.stories.ts",
    "../src/**/*.stories.js",
    "../src/**/*.stories.jsx",
    "../src/**/*.stories.tsx",
    "../src/**/*.stories.mdx",
    "*.d.ts",
    "*.js",
    "preview.ts"
  ]
}
