    htmlCode: inputsHtmlCode,
    angularCode: formsAngularCode
  },
  {
    id: 'cards',
    name: 'Cards & Stats',
    icon: 'credit-card',
    title: 'NCard & Stat Panels',
    desc: 'Interactive cards featuring gradient borders, background gradients on hover, elevation shadows, and data stats with KPI trend lines.',
    sbUrl: `${siteConfig.storybookUrl}/?path=/story/components-card--docs`,
    htmlCode: cardsHtmlCode,
    angularCode: cardsAngularCode
  },
  {
    id: 'chips',
    name: 'Chips & Badges',
    icon: 'tag',
    title: 'NChip & NBadge indicators',
    desc: 'Filter pill chips with active gradient border states and status indicators matching design system token profiles.',
    sbUrl: `${siteConfig.storybookUrl}/?path=/story/components-chip--docs`,
    htmlCode: chipsHtmlCode,
    angularCode: chipsAngularCode
  },
  {
    id: 'overlays',
    name: 'Dialogs & Alerts',
    icon: 'alert-circle',
    title: 'NDialog Modals & Alert Banners',
    desc: 'Accessible dialog containers utilizing overlay backdrops alongside status alert banners for errors, successes, and warnings.',
    sbUrl: `${siteConfig.storybookUrl}/?path=/story/overlay-dialog--docs`,
    htmlCode: overlaysHtmlCode,
    angularCode: overlaysAngularCode
  },
  {
    id: 'progress',
    name: 'Progress & Skeletons',
    icon: 'loader',
    title: 'NProgress Trackers & Shimmer Skeletons',
    desc: 'Linear determinate loading tracks, SVG circular progress meters, and dynamic shimmer skeletons mimicking content loading.',
    sbUrl: `${siteConfig.storybookUrl}/?path=/story/components-progress--docs`,
    htmlCode: progressHtmlCode,
    angularCode: progressAngularCode
  },
  {
    id: 'layouts',
    name: 'Layouts & Timelines',
    icon: 'layout',
    title: 'NShell Navigation & AI Timelines',
    desc: 'App headers, mini sidebars, bottom navigation, and processing pipelines illustrating chronological node states.',
    sbUrl: `${siteConfig.storybookUrl}/?path=/story/layout-shell--docs`,
    htmlCode: layoutsHtmlCode,
    angularCode: layoutsAngularCode
  }
];

const colorTokens = [
  { name: '--nn-blue-primary', value: '#4285F4', desc: 'Primary Google Blue color' },
  { name: '--nn-violet-primary', value: '#7B5CF6', desc: 'Secondary purple accent' },
  { name: '--nn-pink-primary', value: '#D946EF', desc: 'Tertiary violet accent' },
  { name: '--nn-success', value: '#34A853', desc: 'Success green status indicator' },
  { name: '--nn-warning', value: '#FBBC05', desc: 'Warning yellow status indicator' },
  { name: '--nn-error', value: '#EA4335', desc: 'Error red status indicator' },
];

const surfaceTokens = [
  { name: '--nn-bg-canvas', value: '#06060E', desc: 'Deep canvas background color' },
  { name: '--nn-bg-base', value: '#0A0A15', desc: 'Primary card and base container fill' },
  { name: '--nn-surface-1', value: '#0F0F1C', desc: 'Layer 1 surface card backgrounds' },
  { name: '--nn-surface-2', value: '#141426', desc: 'Layer 2 surface cards and active hover state' },
  { name: '--nn-surface-3', value: '#1A1A2E', desc: 'Layer 3 surface dropdown and menu overlays' },
];

const radiusTokens = [
  { name: '--nn-r-xs', value: '4px', desc: 'Border-radius for input fields and text areas' },
  { name: '--nn-r-sm', value: '8px', desc: 'Border-radius for small buttons and badges' },
  { name: '--nn-r-md', value: '12px', desc: 'Border-radius for standard core UI widgets' },
  { name: '--nn-r-lg', value: '16px', desc: 'Border-radius for primary content panels' },
  { name: '--nn-r-xl', value: '20px', desc: 'Border-radius for large dialog panels' },
  { name: '--nn-r-full', value: '9999px', desc: 'Border-radius for badges and pill-shaped elements' },
];
---

<SiteLayout
  title="Neural Angular | Angular-first UI library"
  description={siteConfig.heroDescription}
>
  <!-- Highlight.js style & script CDN imports -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/tokyo-night-dark.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js" is:inline></script>

  <div class="site-shell">
    
    <!-- Header -->
    <header class="site-header" id="main-site-header">
      <a class="brand" href="/">
        <img src="/favicon.svg" class="brand-logo-img" alt="Neural Angular Logo" />
        <span class="brand-copy">
          <strong>{siteConfig.brand}</strong>
          <span>Angular-first UI system</span>
        </span>
      </a>

      <nav class="header-links" aria-label="Sections">
        <a class="nav-link" href="#install-section" id="nav-btn-install">Installation</a>
        <a class="nav-link" href="#showcase-section" id="nav-btn-showcase">Showcase</a>
        <a class="nav-link" href="#tokens-section" id="nav-btn-tokens">Design Tokens</a>
        <a class="nav-link cta" href={siteConfig.storybookUrl} target="_blank" rel="noreferrer" id="nav-btn-docs">
          Documentation &rarr;
        </a>
      </nav>
    </header>

    <main class="landing-main">
      
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="hero-content">
          <div class="eyebrow-row">
            <span class="eyebrow">Published on npm</span>
            <span class="version-badge">v{libraryMeta.version}</span>
            <span class="angular-badge">Angular {libraryMeta.angularRange}</span>
          </div>

          <h1>Angular UI built for real production apps.</h1>
          <p class="hero-desc">{siteConfig.heroDescription}</p>

          <div class="hero-actions">
            <a href="#install-section" class="btn btn-primary" id="hero-btn-get-started">
              Get Started
            </a>
            <a href="#showcase-section" class="btn btn-secondary" id="hero-btn-view-components">
              View Components
            </a>
            <a href={siteConfig.storybookUrl} target="_blank" rel="noreferrer" class="btn btn-tertiary" id="hero-btn-storybook">
              View Documentation
            </a>
          </div>

          <!-- Quick Install Command Box -->
          <div class="hero-install-box">
            <div class="install-input-container">
              <span class="cli-prompt">$</span>
              <input type="text" readonly value={pnpmInstall} id="hero-install-input" aria-label="Install command" />
            </div>
            <button type="button" class="btn-copy" data-copy-text={pnpmInstall} id="hero-btn-copy">
              Copy
            </button>
          </div>
        </div>

        <div class="hero-stats-panel">
          <div class="stat-card">
            <span class="stat-label">Version</span>
            <strong class="stat-value">v{libraryMeta.version}</strong>
            <p>Published & ready</p>
          </div>
          <div class="stat-card">
            <span class="stat-label">Entry Points</span>
            <strong class="stat-value">{libraryMeta.secondaryEntryPoints}+</strong>
            <p>Focused module imports</p>
          </div>
          <div class="stat-card">
            <span class="stat-label">Style Exports</span>
            <strong class="stat-value">{libraryMeta.styleExports}</strong>
            <p>Stylesheets & tokens</p>
          </div>
        </div>
      </section>

      <!-- Getting Started / Installation Section -->
      <section class="section-container" id="install-section">
        <div class="section-header">
          <h2>Getting Started</h2>
          <p>Quick steps to integrate Neural Angular UI into your project workspaces.</p>
        </div>

        <div class="steps-grid">
          
          <!-- Step 1 -->
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Download Package</h3>
            <p>Install the library package using your preferred node package manager.</p>
            
            <div class="tabbed-code-box">
              <div class="code-box-tabs">
                <button class="code-tab-btn active" data-tab-code="pnpm" id="btn-pkg-pnpm">pnpm</button>
                <button class="code-tab-btn" data-tab-code="npm" id="btn-pkg-npm">npm</button>
                <button class="code-tab-btn" data-tab-code="yarn" id="btn-pkg-yarn">yarn</button>
              </div>
              <div class="code-box-panels">
                <div class="code-panel active" data-code-panel="pnpm">
                  <pre><code class="language-bash">{pnpmInstall}</code></pre>
                  <button type="button" class="copy-code-btn" data-copy-text={pnpmInstall} id="btn-copy-pnpm">Copy</button>
                </div>
                <div class="code-panel" data-code-panel="npm">
                  <pre><code class="language-bash">{npmInstall}</code></pre>
                  <button type="button" class="copy-code-btn" data-copy-text={npmInstall} id="btn-copy-npm">Copy</button>
                </div>
                <div class="code-panel" data-code-panel="yarn">
                  <pre><code class="language-bash">{yarnInstall}</code></pre>
                  <button type="button" class="copy-code-btn" data-copy-text={yarnInstall} id="btn-copy-yarn">Copy</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Configure CSS Styles</h3>
            <p>Add token overrides and theme classes into your global <code>styles.scss</code> file:</p>
            <div class="code-wrapper">
              <pre><code class="language-scss">{scssImportCode}</code></pre>
              <button type="button" class="copy-code-btn" data-copy-text={scssImportCode} id="btn-copy-scss">Copy</button>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Provide Application Theme</h3>
            <p>Initialize the active theme configuration in your application bootstraps:</p>
            <div class="code-wrapper">
              <pre><code class="language-typescript">{appConfigCode}</code></pre>
              <button type="button" class="copy-code-btn" data-copy-text={appConfigCode} id="btn-copy-theme-provider">Copy</button>
            </div>
          </div>

        </div>
      </section>

      <!-- Component Showcase Section -->
      <section class="section-container" id="showcase-section">
        <div class="section-header">
          <h2>Interactive Component Sandbox</h2>
          <p>Explore the live HTML output and markup of Neural Angular components directly. Select a category to inspect visual styles, click to toggle states, and copy code snippets.</p>
        </div>

        <div class="sandbox-container">
          <!-- Sidebar tabs -->
          <div class="sandbox-sidebar">
            <h3>Component Library</h3>
            {sandboxTabs.map((tab, idx) => (
              <button 
                class={`sandbox-tab-btn ${idx === 0 ? 'active' : ''}`}
                data-sandbox-tab={tab.id}
                data-title={tab.title}
                data-desc={tab.desc}
                data-sb-url={tab.sbUrl}
                id={`sandbox-tab-${tab.id}`}
              >
                <i data-lucide={tab.icon}></i>
                <span>{tab.name}</span>
              </button>
            ))}
          </div>

          <!-- Sandbox Content -->
          <div class="sandbox-content">
            <!-- Preview Canvas -->
            <div class="sandbox-canvas">
              {sandboxTabs.map((tab, idx) => (
                <div 
                  class={`sandbox-canvas-panel ${idx === 0 ? 'active' : ''}`}
                  data-sandbox-panel={tab.id}
                >
                  <div set:html={tab.htmlCode}></div>
                </div>
              ))}
            </div>

            <!-- Toolbar -->
            <div class="sandbox-toolbar">
              <div class="sandbox-info">
                <span class="sandbox-info-title" id="sandbox-info-title">{sandboxTabs[0].title}</span>
                <span class="sandbox-info-desc" id="sandbox-info-desc">{sandboxTabs[0].desc}</span>
              </div>
              <div class="sandbox-actions">
                <button type="button" class="sandbox-btn-toggle-code" id="sandbox-btn-toggle-code">
                  <i data-lucide="code"></i>
                  <span>Show Angular Code</span>
                </button>
                <a 
                  href={sandboxTabs[0].sbUrl} 
                  target="_blank" 
                  rel="noreferrer" 
                  class="btn btn-secondary nn-btn-sm" 
                  id="sandbox-sb-link"
                  style="height: 32px; padding: 0 14px; font-size: 11.5px;"
                >
                  View Documentation &rarr;
                </a>
              </div>
            </div>

            <!-- Code drawer -->
            <div class="sandbox-code-drawer" id="sandbox-code-drawer">
              <pre><code class="language-xml" id="sandbox-code-pre"></code></pre>
              <button 
                type="button" 
                class="copy-code-btn" 
                id="sandbox-drawer-copy-btn" 
                data-copy-text=""
              >
                Copy
              </button>
            </div>
          </div>
        </div>

        <!-- Hidden container for code sources, accessed by JS -->
        <div class="sandbox-code-sources" style="display: none;">
          {sandboxTabs.map((tab) => (
            <pre class="sandbox-code-source-panel" data-code-panel={tab.id}>
              {tab.angularCode}
            </pre>
          ))}
        </div>
      </section>

      <!-- Design Tokens Section -->
      <section class="section-container" id="tokens-section">
        <div class="section-header">
          <h2>Design Tokens</h2>
          <p>Definitions of core design variable classes. Click any token row to copy the variable to your clipboard.</p>
        </div>

        <div class="tokens-layout-board">
          
          <div class="tokens-nav-tabs">
            <button class="token-tab-trigger active" data-token-tab="colors" id="tab-btn-colors">Colors</button>
            <button class="token-tab-trigger" data-token-tab="surfaces" id="tab-btn-surfaces">Surfaces</button>
            <button class="token-tab-trigger" data-token-tab="radii" id="tab-btn-radii">Border Radius</button>
          </div>

          <div class="token-lists-container">
            
            <!-- Color Tokens List -->
            <div class="token-list-panel active" data-token-panel="colors">
              <div class="tokens-table-wrapper">
                <table class="tokens-display-table">
                  <thead>
                    <tr>
                      <th>Visual</th>
                      <th>CSS Variable</th>
                      <th>Default Value</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {colorTokens.map((tok) => (
                      <tr class="token-interactive-row" data-copy-value={tok.name}>
                        <td>
                          <div class="visual-token-swatch" style={`background-color: ${tok.value};`}></div>
                        </td>
                        <td><code class="token-name-label">{tok.name}</code></td>
                        <td><code class="token-value-label">{tok.value}</code></td>
                        <td>{tok.desc}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Surface Tokens List -->
            <div class="token-list-panel" data-token-panel="surfaces">
              <div class="tokens-table-wrapper">
                <table class="tokens-display-table">
                  <thead>
                    <tr>
                      <th>Visual</th>
                      <th>CSS Variable</th>
                      <th>Default Value</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {surfaceTokens.map((tok) => (
                      <tr class="token-interactive-row" data-copy-value={tok.name}>
                        <td>
                          <div class="visual-token-surface" style={`background-color: ${tok.value};`}></div>
                        </td>
                        <td><code class="token-name-label">{tok.name}</code></td>
                        <td><code class="token-value-label">{tok.value}</code></td>
                        <td>{tok.desc}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Border Radius Tokens List -->
            <div class="token-list-panel" data-token-panel="radii">
              <div class="tokens-table-wrapper">
                <table class="tokens-display-table">
                  <thead>
                    <tr>
                      <th>Visual</th>
                      <th>CSS Variable</th>
                      <th>Default Value</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {radiusTokens.map((tok) => (
                      <tr class="token-interactive-row" data-copy-value={tok.name}>
                        <td>
                          <div class="visual-token-radius" style={`border-radius: ${tok.value};`}></div>
                        </td>
                        <td><code class="token-name-label">{tok.name}</code></td>
                        <td><code class="token-value-label">{tok.value}</code></td>
                        <td>{tok.desc}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

          </div>

        </div>
      </section>

      <!-- Bottom CTA Band -->
      <section class="bottom-cta-band">
        <div class="cta-inner">
          <h2>Ready to discover the complete component catalog?</h2>
          <p>Explore our comprehensive documentation and interactive design system to browse detailed parameters, states, tokens, and code playground models.</p>
          <div class="cta-actions-row">
            <a href={siteConfig.storybookUrl} target="_blank" rel="noreferrer" class="btn btn-primary large" id="cta-btn-storybook">
              View Full Documentation
            </a>
            <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer" class="btn btn-secondary large" id="cta-btn-github">
              View Monorepo &rarr;
            </a>
          </div>
        </div>
      </section>

    </main>

    <!-- Notification Toast -->
    <div id="feedback-toast" class="toast-notification" aria-live="polite">
      Copied to clipboard!
    </div>

    <!-- Footer -->
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} {siteConfig.brand}. Published under MIT License.</p>
      <div class="footer-links">
        <a href={siteConfig.storybookUrl} target="_blank" rel="noreferrer">Documentation</a>
        <a href={siteConfig.npmUrl} target="_blank" rel="noreferrer">npm Package</a>
        <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </footer>
  </div>

  <!-- Client-side tab switcher & copy utility script -->
  <script is:inline>
    // Tab switching for installation steps code block
    document.addEventListener('click', (e) => {
      const codeTabBtn = e.target.closest('.code-tab-btn');
      if (!codeTabBtn) return;

      const targetCode = codeTabBtn.getAttribute('data-tab-code');

      // Set active button styles
      const tabBtns = document.querySelectorAll('.code-tab-btn');
      tabBtns.forEach((btn) => {
        if (btn === codeTabBtn) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Toggle panels
      const panels = document.querySelectorAll('.code-panel');
      panels.forEach((panel) => {
        if (panel.getAttribute('data-code-panel') === targetCode) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });
    });

    // Tab switching for Sandbox
    document.addEventListener('click', (e) => {
      const sandboxTabBtn = e.target.closest('.sandbox-tab-btn');
      if (!sandboxTabBtn) return;

      const targetTab = sandboxTabBtn.getAttribute('data-sandbox-tab');

      // Toggle buttons active class
      const btns = document.querySelectorAll('.sandbox-tab-btn');
      btns.forEach((btn) => {
        if (btn === sandboxTabBtn) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Toggle canvas panels
      const panels = document.querySelectorAll('.sandbox-canvas-panel');
      panels.forEach((panel) => {
        if (panel.getAttribute('data-sandbox-panel') === targetTab) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });

      // Update toolbar metadata (title, description, Storybook URL)
      const title = sandboxTabBtn.getAttribute('data-title');
      const desc = sandboxTabBtn.getAttribute('data-desc');
      const sbUrl = sandboxTabBtn.getAttribute('data-sb-url');

      const infoTitleEl = document.getElementById('sandbox-info-title');
      const infoDescEl = document.getElementById('sandbox-info-desc');
      const sbLinkEl = document.getElementById('sandbox-sb-link');

      if (infoTitleEl) infoTitleEl.textContent = title;
      if (infoDescEl) infoDescEl.textContent = desc;
      if (sbLinkEl) sbLinkEl.setAttribute('href', sbUrl);

      // Hide code drawer when switching tabs
      const codeDrawer = document.getElementById('sandbox-code-drawer');
      const btnToggleCode = document.getElementById('sandbox-btn-toggle-code');
      if (codeDrawer && btnToggleCode) {
        codeDrawer.classList.remove('active');
        btnToggleCode.classList.remove('active');
      }

      // Update the active code panel content
      const codePre = document.getElementById('sandbox-code-pre');
      const activeCodePanel = document.querySelector(`.sandbox-code-source-panel[data-code-panel="${targetTab}"]`);
      if (codePre && activeCodePanel) {
        codePre.textContent = activeCodePanel.textContent.trim();
        // Trigger highlight.js to format this code
        if (window.hljs) {
          codePre.removeAttribute('data-highlighted');
          codePre.className = 'language-xml';
          window.hljs.highlightElement(codePre);
        }
        // Also update data-copy-text attribute on the drawer's copy button
        const drawerCopyBtn = document.getElementById('sandbox-drawer-copy-btn');
        if (drawerCopyBtn) {
          drawerCopyBtn.setAttribute('data-copy-text', activeCodePanel.textContent.trim());
        }
      }
    });

    // Toggle Code Drawer button
    document.addEventListener('click', (e) => {
      const toggleCodeBtn = e.target.closest('#sandbox-btn-toggle-code');
      if (!toggleCodeBtn) return;

      const codeDrawer = document.getElementById('sandbox-code-drawer');
      if (codeDrawer) {
        const isActive = codeDrawer.classList.toggle('active');
        toggleCodeBtn.classList.toggle('active', isActive);
      }
    });

    // Tab switching for Design Tokens board
    document.addEventListener('click', (e) => {
      const tabBtn = e.target.closest('.token-tab-trigger');
      if (!tabBtn) return;

      const targetTab = tabBtn.getAttribute('data-token-tab');

      // Toggle buttons active class
      const btns = document.querySelectorAll('.token-tab-trigger');
      btns.forEach((btn) => {
        if (btn === tabBtn) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Toggle table panels
      const panels = document.querySelectorAll('.token-list-panel');
      panels.forEach((panel) => {
        if (panel.getAttribute('data-token-panel') === targetTab) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });
    });

    // Clipboard Copy feedback toast utility
    const toast = document.getElementById('feedback-toast');
    function showToast(message) {
      if (!toast) return;
      toast.textContent = message;
      toast.classList.add('active');
      window.setTimeout(() => {
        toast.classList.remove('active');
      }, 2000);
    }

    // Dynamic click to copy handler for copy buttons
    document.addEventListener('click', async (e) => {
      const copyBtn = e.target.closest('[data-copy-text]');
      if (!copyBtn) return;

      const text = copyBtn.getAttribute('data-copy-text');
      try {
        await navigator.clipboard.writeText(text);
        showToast('Copied code snippet to clipboard!');
      } catch {
        showToast('Failed to copy.');
      }
    });

    // Copy Token Variables on row click
    document.addEventListener('click', async (e) => {
      const tokenRow = e.target.closest('.token-interactive-row');
      if (!tokenRow) return;

      const varName = tokenRow.getAttribute('data-copy-value');
      if (!varName) return;

      try {
        await navigator.clipboard.writeText(varName);
        showToast(`Copied token: ${varName}`);
      } catch {
        showToast('Failed to copy token.');
      }
    });
  </script>
  <!-- Lucide icons loader -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      if (window.lucide) {
        window.lucide.createIcons();
      }

      // Initialize highlight.js on load
      if (window.hljs) {
        window.hljs.highlightAll();
      }

      // Initialize Sandbox code block on load
      const codePre = document.getElementById('sandbox-code-pre');
      const activeCodePanel = document.querySelector('.sandbox-code-source-panel[data-code-panel="buttons"]');
      if (codePre && activeCodePanel) {
        codePre.textContent = activeCodePanel.textContent.trim();
        if (window.hljs) {
          codePre.removeAttribute('data-highlighted');
          codePre.className = 'language-xml';
          window.hljs.highlightElement(codePre);
        }
        const drawerCopyBtn = document.getElementById('sandbox-drawer-copy-btn');
        if (drawerCopyBtn) {
          drawerCopyBtn.setAttribute('data-copy-text', activeCodePanel.textContent.trim());
        }
      }
    });
  </script>
</SiteLayout>
