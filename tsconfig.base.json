{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "customConditions": ["@neural/angular-ui"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@neural/angular-ui": ["packages/ui/src/index.ts"],
      "@neural/angular-ui/avatar": ["packages/ui/src/avatar/index.ts"],
      "@neural/angular-ui/badge": ["packages/ui/src/badge/index.ts"],
      "@neural/angular-ui/button": ["packages/ui/src/button/index.ts"],
      "@neural/angular-ui/card": ["packages/ui/src/card/index.ts"],
      "@neural/angular-ui/chip": ["packages/ui/src/chip/index.ts"],
      "@neural/angular-ui/command-bar": ["packages/ui/src/command-bar/index.ts"],
      "@neural/angular-ui/empty-state": ["packages/ui/src/empty-state/index.ts"],
      "@neural/angular-ui/icon": ["packages/ui/src/icon/index.ts"],
      "@neural/angular-ui/input": ["packages/ui/src/input/index.ts"],
      "@neural/angular-ui/page-header": ["packages/ui/src/page-header/index.ts"],
      "@neural/angular-ui/progress": ["packages/ui/src/progress/index.ts"],
      "@neural/angular-ui/select": ["packages/ui/src/select/index.ts"],
      "@neural/angular-ui/shell": ["packages/ui/src/shell/index.ts"],
      "@neural/angular-ui/sidebar": ["packages/ui/src/sidebar/index.ts"],
      "@neural/angular-ui/spinner": ["packages/ui/src/spinner/index.ts"],
      "@neural/angular-ui/status-dot": ["packages/ui/src/status-dot/index.ts"],
      "@neural/angular-ui/tabs": ["packages/ui/src/tabs/index.ts"],
      "@neural/angular-ui/textarea": ["packages/ui/src/textarea/index.ts"],
      "@neural/angular-ui/theme": ["packages/ui/src/theme/index.ts"],
      "@neural/angular-ui/toolbar": ["packages/ui/src/toolbar/index.ts"],
      "@neural/angular-ui/tokens": ["packages/ui/src/tokens/index.ts"]
    }
  }
}
