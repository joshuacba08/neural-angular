{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "customConditions": ["@neural/angular-ui"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@neural/angular-ui": ["packages/ui/src/index.ts"],
      "@neural/angular-ui/theme": ["packages/ui/src/theme/index.ts"],
      "@neural/angular-ui/tokens": ["packages/ui/src/tokens/index.ts"]
    }
  }
}
